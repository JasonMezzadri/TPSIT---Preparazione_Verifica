<html>
<head>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        header, footer { background: #f4f4f4; padding: 15px; border: 1px solid #ccc; text-align: center; }
        table { border-collapse: collapse; width: 100%; margin-top: 15px; }
        table, th, td { border: 1px solid #000; padding: 10px; }
        th { background: #eee; }
    </style>
</head>
<body>
    <header><h1>Header Scelta - Verifica BS5</h1></header>
    
    <h3>Tabella Riassuntiva Esercizi</h3>
    <table>
        <tr><th>Esercizio</th><th>Livello</th></tr>
        <% listaTask.forEach(item => { %>
            <tr><td><%= item.nome %></td><td><%= item.tipo %></td></tr>
        <% }) %>
    </table>
    
    <div style="margin-top: 20px;">
        <a href="/news">News</a> | 
        <a href="/contatore">Contatore</a> | 
        <a href="/ricetta">Ricetta</a> | 
        <a href="/RegistraDescrizione">Registra Dati</a>
    </div>

    <footer style="margin-top: 30px;">Footer Scelta - Classe BS5</footer>
</body>
</html>
